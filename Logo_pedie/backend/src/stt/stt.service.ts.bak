import { Injectable, Logger } from '@nestjs/common';
import * as fs from 'fs';
import * as path from 'path';
import ffmpeg from 'fluent-ffmpeg';
import * as ffmpegInstaller from '@ffmpeg-installer/ffmpeg';

// Import de Transformers.js (100% local, pas de code C++ sur Windows)
import { pipeline } from '@xenova/transformers';

ffmpeg.setFfmpegPath(ffmpegInstaller.path);

@Injectable()
export class SttService {
  private readonly logger = new Logger(SttService.name);
  private transcriber: any = null;

  constructor() {
    this.initTranscriber();
  }

  // Chargement du modèle en cache
  private async initTranscriber() {
    this.logger.log('Chargement du modèle Whisper (ONNX CPU)...');
    try {
      this.transcriber = await pipeline('automatic-speech-recognition', 'Xenova/whisper-tiny', {
        // Options pour l'utiliser sans soucis
        quantized: true,
      });
      this.logger.log('Modèle Whisper 100% local chargé !');
    } catch (e) {
      this.logger.error('Erreur chargement modèle:', e);
    }
  }

  async transcribe(filePath: string): Promise<string> {
    const wavPath = filePath + '-converted.wav';

    try {
      if (!this.transcriber) {
        throw new Error("Modèle IA non chargé");
      }

      this.logger.log(`Conversion de ${filePath} en WAV 16kHz...`);
      await new Promise((resolve, reject) => {
        ffmpeg(filePath)
          .toFormat('wav')
          .audioFrequency(16000)
          .audioChannels(1)
          .on('end', resolve)
          .on('error', reject)
          .save(wavPath);
      });

      this.logger.log(`Début de la transcription Transformers.js pour ${wavPath}`);
      
      // Lecture du binaire Converti en float 32 (necessaire pour Transformer.js)
      // Transformers.js reconnait aussi directement l'audio URL, on peut essayer :
      const transcript = await this.transcriber(wavPath, {
          chunk_length_s: 30,
          stride_length_s: 5,
        // language: 'french', // vous pouvez forcer la langue si souhaité
      });

      const fullText = transcript?.text || '';

      this.logger.log(`Transcription terminée : ${fullText}`);
      return fullText;
    } catch (error) {
      this.logger.error(`Erreur de transcription : ${error.message}`, error.stack);
      return 'Erreur lors de la transcription';
    } finally {
      // Nettoyage des fichiers temporaires (audio original et converti)
      [filePath, wavPath].forEach((file) => {
        if (fs.existsSync(file)) {
          fs.unlink(file, (err) => {
            if (err) this.logger.error(`Erreur suppression fichier ${file}`, err);
          });
        }
      });
    }
  }
}


